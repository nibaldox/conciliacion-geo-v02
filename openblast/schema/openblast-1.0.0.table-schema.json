{
  "fields": [
    {"name": "hole_id", "type": "string", "constraints": {"minLength": 1}, "description": "Unique hole identifier."},
    {"name": "blast_id", "type": "string", "constraints": {"minLength": 1}, "description": "Blast/polygon identifier."},
    {"name": "sequence", "type": "integer", "constraints": {"minimum": 0}, "description": "Initiation sequence row."},
    {"name": "easting", "type": "number", "description": "Easting (m). CRS declared in datapackage.json."},
    {"name": "northing", "type": "number", "description": "Northing (m)."},
    {"name": "elevation", "type": "number", "description": "Collar elevation (m)."},
    {"name": "dip", "type": "number", "constraints": {"minimum": -90, "maximum": 90}, "description": "Dip in degrees (positive downward)."},
    {"name": "azimuth", "type": "number", "constraints": {"minimum": 0, "maximum": 360}, "description": "Azimuth in degrees clockwise from North."},
    {"name": "hole_length_planned", "type": "number", "constraints": {"minimum": 0}, "description": "Planned drilled length (m)."},
    {"name": "hole_length_actual", "type": "number", "constraints": {"minimum": 0}, "description": "Actual drilled length (m)."},
    {"name": "diameter_mm", "type": "number", "constraints": {"minimum": 0}, "description": "Bit diameter (mm)."},
    {"name": "burden", "type": "number", "constraints": {"minimum": 0}, "description": "Burden (m)."},
    {"name": "spacing", "type": "number", "constraints": {"minimum": 0}, "description": "Spacing (m)."},
    {"name": "subdrill", "type": "number", "constraints": {"minimum": 0}, "description": "Subdrilling / pasadura (m)."},
    {"name": "explosive_type", "type": "string", "constraints": {"enum": ["ANFO", "Heavy ANFO", "Emulsion", "Bulk emulsion", "ANFO + Emulsion", "Other"]}, "description": "Main explosive category."},
    {"name": "explosive_kg_actual", "type": "number", "constraints": {"minimum": 0}, "description": "Actual kg loaded."},
    {"name": "explosive_kg_planned", "type": "number", "constraints": {"minimum": 0}, "description": "Planned kg per design."},
    {"name": "explosive_density_g_cc", "type": "number", "constraints": {"minimum": 0, "maximum": 2}, "description": "In-situ explosive density (g/cm³)."},
    {"name": "emulsion_kg", "type": "number", "constraints": {"minimum": 0}, "description": "Kg of emulsion (if mix)."},
    {"name": "anfo_kg", "type": "number", "constraints": {"minimum": 0}, "description": "Kg of ANFO (if mix)."},
    {"name": "bulk_kg", "type": "number", "constraints": {"minimum": 0}, "description": "Kg of bulk-loaded explosive."},
    {"name": "stemming_length_m", "type": "number", "constraints": {"minimum": 0}, "description": "Stemming (taco) length (m)."},
    {"name": "mine_site", "type": "string", "constraints": {"minLength": 1}, "description": "Mine site / pit identifier."},
    {"name": "bench_id", "type": "string", "constraints": {"minLength": 1}, "description": "Bench identifier."},
    {"name": "shot_at", "type": "string", "format": "date-time", "description": "ISO-8601 detonation timestamp with UTC offset."},
    {"name": "operator", "type": "string", "description": "Loading company or crew."},
    {"name": "rock_mass_rating", "type": "number", "constraints": {"minimum": 0, "maximum": 100}, "description": "Bieniawski RMR (0-100)."},
    {"name": "density_rock_t_m3", "type": "number", "constraints": {"minimum": 1.5, "maximum": 4.0}, "description": "In-situ rock density (t/m³)."},
    {"name": "initiation_system", "type": "string", "constraints": {"enum": ["Nonel", "Electronic", "Detonating cord", "Other"]}, "description": "Initiation system."},
    {"name": "delay_ms", "type": "number", "constraints": {"minimum": 0}, "description": "Total delay (ms)."},
    {"name": "bottom_hole_x", "type": "number", "description": "Bottom-hole X (if survey)."},
    {"name": "bottom_hole_y", "type": "number", "description": "Bottom-hole Y (if survey)."},
    {"name": "bottom_hole_z", "type": "number", "description": "Bottom-hole Z (if survey)."},
    {"name": "decoupling_ratio", "type": "number", "description": "Charge/hole diameter ratio."},
    {"name": "comment", "type": "string", "description": "Free-text comment."},
    {"name": "anomaly_flag", "type": "string", "constraints": {"enum": ["loaded", "misfire", "cutoff", "wet_hole", "bootleg", "refilled", "empty"]}, "description": "Anomaly classification."}
  ],
  "primaryKey": "hole_id",
  "openblast_version": "1.0.0"
}